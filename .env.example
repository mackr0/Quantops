# Alpaca API Credentials — Single account (used by scheduler.py)
# Get yours at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Alpaca API Credentials — Multi-account (used by multi_scheduler.py)
# Each segment needs its own paper trading account.
SMALLCAP_ALPACA_KEY=your_smallcap_api_key_here
SMALLCAP_ALPACA_SECRET=your_smallcap_secret_key_here

MIDCAP_ALPACA_KEY=your_midcap_api_key_here
MIDCAP_ALPACA_SECRET=your_midcap_secret_key_here

LARGECAP_ALPACA_KEY=your_largecap_api_key_here
LARGECAP_ALPACA_SECRET=your_largecap_secret_key_here

# Anthropic API Key (for Claude AI analysis)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email Notifications (Resend)
# Get your API key at https://resend.com
RESEND_API_KEY=your_resend_api_key_here
NOTIFICATION_EMAIL=your@email.com
